# =============================================================================
# AI-FORENSICS — Variables d'environnement
# =============================================================================
# IMPORTANT : Copier ce fichier en ".env" et remplir les vraies valeurs.
#             Le fichier ".env" ne doit JAMAIS être commité dans Git.
#             Le fichier ".env.example" (celui-ci) PEUT être commité :
#             il sert de documentation, sans aucune valeur réelle.
#
#             Paramétrer les bons droits sur le fichier .env (chmod 600 .env)
#
# =============================================================================

# --- MongoDB (compte applicatif — utilisé par tous les workers) ---
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=influence_app
MONGO_PASSWORD=CHANGER_MOI
MONGO_DB=influence_detection
MONGO_AUTH_DB=influence_detection

# --- MongoDB (compte admin — utilisé uniquement par schema.py create_indexes) ---
MONGO_ADMIN_USER=admin
MONGO_ADMIN_PASSWORD=CHANGER_MOI

# --- Neo4j (utilisé par le worker NETWORK) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGER_MOI
